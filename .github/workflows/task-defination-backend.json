{
    "family": "rag-voice-agent-backend-td",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::147853513208:role/rag-voice-agent-execution-role",
    "containerDefinitions": [
        {
            "name": "rag-voice-agent-backend-container",
            "image": "147853513208.dkr.ecr.us-east-1.amazonaws.com/rag-voice-agent-backend:latest",
            "portMappings": [
                {
                    "containerPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "DB_NAME",
                    "value": "rag_voice_agent_db"
                }
            ],
            "secrets": [
                {
                    "name": "MONGO_URL",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:147853513208:secret:rag-voice-agent-mongo-url-123456789012"
                },
                {
                    "name": "DEEPGRAM_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:147853513208:secret:rag-voice-agent-deepgram-api-key-123456789012"
                },
                {
                    "name": "OPENAI_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:147853513208:secret:rag-voice-agent-groq-api-key-123456789012"
                },
                {
                    "name": "GOOGLE_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:147853513208:secret:rag-voice-agent-google-api-key-123456789012"
                },
                {
                    "name": "ELEVENLABS_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:147853513208:secret:rag-voice-agent-elevenlabs-api-key-123456789012"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/rag-voice-agent-backend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
                "interval": 30,
                "timeout": 10,
                "retries": 3,
                "startPeriod": 40
            }
        }
    ]
}